# ── Frontend environment — Lantara v2 ──────────────────────────────────────
# Copy to .env.local for local development. NEVER commit .env.local.

# SSO (OIKN staff login) — leave empty to hide the SSO button on StaffLoginPage.
# VITE_OIDC_AUTHORITY is the Keycloak authorization endpoint for your realm.
# Both vars must be set for the SSO button to appear (isSsoEnabled() checks both).
VITE_OIDC_AUTHORITY=
VITE_OIDC_CLIENT_ID=
