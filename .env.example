# ─────────────────────── Lantara v2 — environment template ───────────────────
# Copy to .env and fill in real values. NEVER commit .env.
# All defaults below are for local development only.

# Django
SECRET_KEY=django-insecure-replace-me-with-50-random-chars
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# JWT
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=7

# Database (postgres service in compose)
POSTGRES_DB=lantara
POSTGRES_USER=lantara
POSTGRES_PASSWORD=lantara
DATABASE_URL=postgres://lantara:lantara@db:5432/lantara

# Redis (redis service in compose)
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=lantara
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_PORT=9001
USE_S3=true

# CORS (frontend origin in dev)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Email (use console backend in dev; set SMTP vars in prod)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@lantara.ikn.go.id

# Superadmin bootstrap (created on first docker compose up)
SUPERADMIN_EMAIL=admin@lantara.ikn.go.id
SUPERADMIN_PASSWORD=changeme-in-prod

# App port (nginx)
APP_PORT=80

# Feature flags
FEATURE_TTE_ENABLED=false
FEATURE_RDTR_REAL_SPATIAL=false
FEATURE_WHATSAPP_ENABLED=false

# WhatsApp adapter (Mekari / WABA) — only needed when FEATURE_WHATSAPP_ENABLED=true
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
